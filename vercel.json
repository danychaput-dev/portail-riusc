{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/camp-alertes",
      "schedule": "*/5 * * * *"
    }
  ]
}
