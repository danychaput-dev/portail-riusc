## ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

## ─── Mapbox ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

## ─── n8n ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_N8N_BASE_URL=https://n8n.your-domain.ca

## ─── Twilio ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TWILIO_PHONE=+1XXXXXXXXXX
# Clés Twilio — utilisées par le proxy /api/admin/operations/n8n-webhook pour
# que n8n puisse envoyer des SMS sans avoir ces clés en dur dans ses workflows.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

## ─── Anthropic (IA) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

## ─── Optionnel ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_MAINTENANCE=true      # Active la page de maintenance

## ─── Cron / Workflows automatisés ────────────────────────────────────────────
# Secret partagé entre le portail et n8n pour autoriser l'envoi du rapport
# de validation-donnees (/api/admin/validation-donnees?envoyer=true).
# Génère une chaîne aléatoire longue, ex: openssl rand -hex 32
# N8n doit envoyer le header: Authorization: Bearer <valeur>
VALIDATION_CRON_SECRET=
