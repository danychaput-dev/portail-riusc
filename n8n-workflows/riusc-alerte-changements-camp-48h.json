      "name": "6. Collecter log_ids",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1840, 240]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://portail.riusc.ca/api/admin/camp/changements-en-attente",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
