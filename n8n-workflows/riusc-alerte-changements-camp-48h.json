      "parameters": {
        "jsCode": "// Collecter tous les log_id des changements reussis\nconst items = $input.all();\nconst logIds = items.map(i => i.json.log_id).filter(Boolean);\nreturn [{ json: { log_ids: logIds } }];"
      },
