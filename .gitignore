# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# scripts utilitaires (ne jamais commiter de scripts avec des cles)
/scripts-local/
check_*.js
diagnostic-*.py
import-*.py
organiser-*.js
upload-*.mjs
create_client.txt
scripts/extract_gmail_certificats/credentials.json
scripts/extract_gmail_certificats/token.json
scripts/extract_gmail_certificats/files/
scripts/extract_gmail_certificats/rapport.csv